# 后端配置示例
# 复制本文件为 backend/.env 后再填写真实值，切勿提交包含真实密钥的 .env

# 应用服务
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175,http://127.0.0.1:5176,http://127.0.0.1:3000

# 主文本模型（HelloAgents / OpenAI 兼容接口）
LLM_MODEL_ID=deepseek-v4-flash
LLM_API_KEY=请填写你的主文本模型密钥
LLM_BASE_URL=https://api.deepseek.com
LLM_TIMEOUT=60

# Qwen-VL 多模态模型
QWEN_API_KEY=请填写你的 Qwen 密钥
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL_ID=qwen-vl-plus

# ── 高德地图 Key（必填！否则行程规划/导览/天气功能不可用）───────
# 申请地址：https://console.amap.com/dev/key/app
# 需要创建「Web服务」类型的 Key，用于后端 POI 搜索、天气查询、地理编码等
AMAP_API_KEY=请填写你的高德 Web 服务 Key
UNSPLASH_ACCESS_KEY=请填写你的 Unsplash Access Key（可选）
UNSPLASH_SECRET_KEY=请填写你的 Unsplash Secret Key（可选）

# 可选：数据广场洞察所需的本地 Excel 数据文件
# 可填写相对仓库根目录的路径，例如：data/insights/scenic-insights.xlsx
# 未配置时 /api/plaza/insights 会返回明确提示，但不会阻塞后端启动
SCENIC_INSIGHTS_EXCEL_PATH=

# 视频生成运行时配置（Docker Compose 默认会自动注入）
VIDEO_GENERATOR_DIR=video-generator
VIDEO_MEDIA_ROOT=
VIDEO_OUTPUT_SUBDIR=output
VIDEO_AUDIO_SUBDIR=audio
VIDEO_IMAGE_SUBDIR=images
VIDEO_OUTPUT_KEEP_COUNT=5
VIDEO_TEMP_KEEP_DAYS=2
EDGE_TTS_BIN=
REMOTION_CONCURRENCY=4
PUPPETEER_EXECUTABLE_PATH=
